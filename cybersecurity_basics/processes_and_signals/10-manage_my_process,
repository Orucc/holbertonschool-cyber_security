#!/usr/bin/env bash
# Init script to manage manage_my_process

PIDFILE="/tmp/my_process.pid"

start() {
    ./manage_my_process &
    echo $! > "$PIDFILE"
    echo "manage_my_process started"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    echo "manage_my_process stopped"
}

restart() {
    # suppress output from stop and start
    stop > /dev/null
    start > /dev/null
    echo "manage_my_process restarted"
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
